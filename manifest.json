{
  "name": "cortex-plugin-contract-review",
  "version": "1.0.0",
  "description": "Legal Contract Review Assistant — Analyze NDAs/MSAs/SOWs/DPAs for risky clauses, non-standard terms, redlines",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-contract-review",
  "homepage": "https://cortexprism.io/marketplace/plugins/contract-review",
  "capabilities": ["tools", "network:fetch"],
  "tools": [
    {
      "name": "contract_analyze",
      "description": "Analyze contract for risks and non-standard terms",
      "params": []
    },
    {
      "name": "contract_compare",
      "description": "Compare against approved fallback positions",
      "params": []
